{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NormalizedEvent",
  "type": "object",
  "required": ["id", "timestamp", "source", "raw_source", "rule_id", "rule_name", "severity", "confidence", "asset"],
  "properties": {
    "id": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "source": {"enum": ["suricata", "wazuh", "simulator", "manual"]},
    "raw_source": {"type": "string"},
    "rule_id": {"type": "string"},
    "rule_name": {"type": "string"},
    "severity": {"enum": ["informational", "low", "medium", "high", "critical"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "asset": {"type": "object"},
    "observables": {"type": "array"},
    "attack": {"type": "array"},
    "tags": {"type": "array"},
    "raw": {"type": "object"}
  }
}

