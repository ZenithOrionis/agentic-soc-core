# Production template. Copy to .env.production and replace every CHANGE_ME value.
# Do not commit the populated file.

ENVIRONMENT=production
PROJECT_NAME=agentic-soc-core

# Must be at least 32 random bytes. Example generation:
# openssl rand -base64 48
SOC_API_KEY=CHANGE_ME_WITH_STRONG_RANDOM_VALUE

# Production response posture:
# dry-run: record actions only
# active-demo: only update SOC app state
# docker-active: requires explicit Docker socket mount and label-scoped executor extension
RESPONSE_MODE=dry-run
DOCKER_CONTROL_ENABLED=false
REQUIRE_MANUAL_APPROVAL=true
RESPONSE_APPROVAL_TOKEN=CHANGE_ME_WITH_SEPARATE_STRONG_RANDOM_VALUE
DEMO_CONTAINER_LABEL=soc.demo.scope=agentic-soc-core

SOC_DB_PATH=/data/soc.db
REPORT_DIR=/data/reports
ARTIFACT_DIR=/data/artifacts
POLICY_FILE=/app/shared/policy/policy.yaml
LOCAL_REPUTATION_FILE=/app/infra/seed/local_reputation.json

NORMALIZER_URL=http://normalizer:8000
ORCHESTRATOR_URL=http://soc-orchestrator:8000
RESPONSE_EXECUTOR_URL=http://response-executor:8000
EXPLAINABILITY_URL=http://explainability-service:8000
INTEGRATION_ADAPTER_URL=http://integration-adapters:8000

# Replace adapter URLs with real systems when deploying beyond the local adapter boundary.
THEHIVE_URL=http://integration-adapters:8000/thehive
THEHIVE_API_KEY=CHANGE_ME_THEHIVE_API_KEY
CORTEX_URL=http://integration-adapters:8000/cortex
CORTEX_API_KEY=CHANGE_ME_CORTEX_API_KEY
SHUFFLE_URL=http://integration-adapters:8000/shuffle
SHUFFLE_API_KEY=CHANGE_ME_SHUFFLE_API_KEY

AUTO_RESPONSE_ENABLED=true
OLLAMA_ENABLED=true
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_TEMPERATURE=0.1
OLLAMA_AUTHORITY_MODE=advisory
OLLAMA_AUTHORITY_MIN_CONFIDENCE=0.85
OLLAMA_AUTHORITY_MAX_RISK=medium
OLLAMA_EXECUTION_USE_APPROVAL_TOKEN=false
LOG_LEVEL=INFO
JSON_LOGS=true
DEMO_UI_TITLE=Agentic SOC Core
UI_SECURE_COOKIE=true
PYTHONDONTWRITEBYTECODE=1
