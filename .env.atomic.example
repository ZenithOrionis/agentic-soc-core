# Atomic Red Team default attack backend configuration.
# Copy to .env.atomic and tune after previewing Atomic tests.
#
# IMPORTANT:
# - Keep Preview until you choose explicit test numbers.
# - Execute mode requires ATOMIC_REAL_ATTACKS_ENABLED=true and explicit test numbers.
# - Atomic tests can modify the host. Use a disposable lab VM when possible.

ATOMIC_DEFAULT_MODE=Preview
ATOMIC_REAL_ATTACKS_ENABLED=false
# Windows example: C:\AtomicRedTeam
# Kali/Linux example: /opt/AtomicRedTeam
ATOMIC_RED_TEAM_PATH=

# Comma-separated Atomic test numbers per scenario.
# Fill these after running Preview and CheckPrereqs.
ATOMIC_TESTS_OUTBOUND_BEACON=
ATOMIC_TESTS_SUSPICIOUS_SCRIPT=
ATOMIC_TESTS_BRUTEFORCE_SUCCESS=
ATOMIC_TESTS_EXFIL_BURST=
ATOMIC_TESTS_PERSISTENCE_LIKE=
ATOMIC_TESTS_SUSPICIOUS_DOWNLOAD=
ATOMIC_TESTS_REVERSE_SHELL_LIKE=
