# AegisCore local-only defaults.
# Copy to .env only if you want to override values; the compose file works with these defaults.

PROJECT_NAME=agentic-soc-core
SOC_DB_PATH=/data/soc.db
REPORT_DIR=/data/reports
ARTIFACT_DIR=/data/artifacts

# Custom service URLs inside Docker networks.
NORMALIZER_URL=http://normalizer:8000
ORCHESTRATOR_URL=http://soc-orchestrator:8000
RESPONSE_EXECUTOR_URL=http://response-executor:8000
EXPLAINABILITY_URL=http://explainability-service:8000
INTEGRATION_ADAPTER_URL=http://integration-adapters:8000
THREAT_SIMULATOR_URL=http://threat-simulators:8000

# Safe demo response mode.
# active-demo applies changes to the local SOC state store only. Docker control remains disabled below.
ENVIRONMENT=demo
SOC_API_KEY=local-demo-api-key
RESPONSE_MODE=active-demo
DOCKER_CONTROL_ENABLED=false
REQUIRE_MANUAL_APPROVAL=auto
RESPONSE_APPROVAL_TOKEN=local-demo-approval-token
DEMO_CONTAINER_LABEL=soc.demo.scope=agentic-soc-core

# Local fake credentials and API keys for the lite adapters.
THEHIVE_URL=http://integration-adapters:8000/thehive
THEHIVE_API_KEY=local-demo-thehive-key
CORTEX_URL=http://integration-adapters:8000/cortex
CORTEX_API_KEY=local-demo-cortex-key
SHUFFLE_URL=http://integration-adapters:8000/shuffle
SHUFFLE_API_KEY=local-demo-shuffle-key

# Policy tuning.
AUTO_RESPONSE_ENABLED=true
POLICY_FILE=/app/shared/policy/policy.yaml
LOCAL_REPUTATION_FILE=/app/infra/seed/local_reputation.json

# Optional local Ollama analyst. Start with `docker compose --profile ai up -d ollama ollama-pull`.
OLLAMA_ENABLED=false
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_TEMPERATURE=0.1
OLLAMA_AUTHORITY_MODE=advisory
OLLAMA_AUTHORITY_MIN_CONFIDENCE=0.80
OLLAMA_AUTHORITY_MAX_RISK=medium
OLLAMA_EXECUTION_USE_APPROVAL_TOKEN=false

# Runtime logging.
LOG_LEVEL=INFO
JSON_LOGS=true

# UI.
DEMO_UI_TITLE=AegisCore
